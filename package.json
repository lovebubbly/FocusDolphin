{
  "name": "focus-dolphin",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:extension && npm run build:content && npm run verify:build",
    "build:extension": "vite build",
    "build:content": "vite build --config vite.content.config.ts",
    "verify:build": "node scripts/verify-build.mjs",
    "package:release": "npm run build && python3 scripts/package-release.py",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && python3 scripts/test-package-release.py"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/chrome": "^0.0.326",
    "@types/node": "^24.0.10",
    "daisyui": "^5.6.13",
    "pretendard": "^1.3.9",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.3",
    "vite": "^7.0.2",
    "vitest": "^3.2.4"
  }
}

{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "version": "1.0.0",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/focusdolphin-16.png",
    "32": "icons/focusdolphin-32.png",
    "48": "icons/focusdolphin-48.png",
    "128": "icons/focusdolphin-128.png"
  },
  "action": {
    "default_title": "__MSG_appName__",
    "default_popup": "src/pages/popup/index.html",
    "default_icon": {
      "16": "icons/focusdolphin-16.png",
      "32": "icons/focusdolphin-32.png",
      "48": "icons/focusdolphin-48.png",
      "128": "icons/focusdolphin-128.png"
    }
  },
  "options_page": "src/pages/options/index.html",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms"
  ],
  "optional_permissions": ["history"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/pages/blocked/index.html",
        "assets/focusdolphin-atlas.png",
        "assets/PretendardVariable.woff2",
        "icons/focusdolphin-128.png"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
